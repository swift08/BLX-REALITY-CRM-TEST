# ============================================================
# BLX Realty CRM — Environment Variables Template
# Copy this file to .env and fill in all required values.
# IMPORTANT: Never commit .env to source control.
# ============================================================

# ── Client-Side (Vite, exposed to browser) ──────────────────
# These are prefixed with VITE_ and safe to include in frontend bundles.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ── Server-Side (API functions, NEVER exposed to browser) ───
# These are read only by api/crm.ts and api/meta/webhook.ts running on Vercel serverless.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# ── CORS Security ────────────────────────────────────────────
# Set to your deployed domain in production (e.g. https://crm.blxrealty.com).
# Leave unset or use * only for local development.
ALLOWED_ORIGIN=https://your-deployment-domain.com

# ── Meta Lead Ads Integration ────────────────────────────────
# Required for Facebook/Instagram Lead Ads webhook auto-capture.
# See DEPLOYMENT.md for setup steps and App Review requirements.
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_VERIFY_TOKEN=your-meta-webhook-handshake-verification-token
META_ACCESS_TOKEN=your-long-lived-page-or-system-user-access-token
META_GRAPH_VERSION=v23.0
